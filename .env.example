# Copy values into src/config.ts (React Native bare — no runtime .env loader yet)

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (publishable) key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: email/password user for simulator dev testing
DEV_EMAIL=
DEV_PASSWORD=

# Google Sign-In (native). Copy into src/config.ts.
# Web Client ID from Google Cloud (also paste into Supabase Google provider).
# GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# iOS Client ID (bundle ID com.kishansagathiya.donna).
# GOOGLE_IOS_CLIENT_ID=123456789-yyyy.apps.googleusercontent.com
# After creating the iOS client, add its REVERSED_CLIENT_ID to
# ios/Donna/Info.plist under CFBundleURLTypes → CFBundleURLSchemes.
