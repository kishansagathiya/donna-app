# Copy values into src/config.ts (React Native bare — no runtime .env loader yet)

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (publishable) key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: email/password user for simulator dev testing
DEV_EMAIL=
DEV_PASSWORD=

# Google Sign-In (native). Values live in src/config.ts.
# GOOGLE_WEB_CLIENT_ID=649652106727-mohbcdb0r5ahrtg8qbnan566tvorv164.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=649652106727-anj5lq5cbq0683p122j69jqenurh56m5.apps.googleusercontent.com
# REVERSED_CLIENT_ID URL scheme is in ios/Donna/Info.plist.
